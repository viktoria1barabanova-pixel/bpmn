<mxfile host="app.diagrams.net">
  <diagram name="BPMN Pro">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Lanes -->
        <mxCell id="lane1" value="Система (Bitrix)" style="swimlane;horizontal=0;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1800" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="lane2" value="Менеджер" style="swimlane;horizontal=0;" vertex="1" parent="1">
          <mxGeometry x="0" y="200" width="1800" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="lane3" value="Контроль" style="swimlane;horizontal=0;" vertex="1" parent="1">
          <mxGeometry x="0" y="400" width="1800" height="200" as="geometry"/>
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;fillColor=#d5e8d4;" vertex="1" parent="lane1">
          <mxGeometry x="40" y="60" width="60" height="60" as="geometry"/>
        </mxCell>

        <!-- Assign -->
        <mxCell id="assign" value="Определить ответственного" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="lane1">
          <mxGeometry x="140" y="60" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Gateway -->
        <mxCell id="gw1" value="Ответственный найден?" style="rhombus;fillColor=#fff2cc;" vertex="1" parent="lane1">
          <mxGeometry x="380" y="50" width="80" height="80" as="geometry"/>
        </mxCell>

        <!-- Assign main -->
        <mxCell id="assignMain" value="Назначить менеджера" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="lane1">
          <mxGeometry x="500" y="20" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Assign reserve -->
        <mxCell id="assignReserve" value="Назначить резервного" style="rounded=1;fillColor=#f8cecc;" vertex="1" parent="lane1">
          <mxGeometry x="500" y="120" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Merge -->
        <mxCell id="merge" style="ellipse;" vertex="1" parent="lane1">
          <mxGeometry x="740" y="60" width="20" height="20" as="geometry"/>
        </mxCell>

        <!-- Update -->
        <mxCell id="update" value="Обновить поля" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="lane1">
          <mxGeometry x="800" y="60" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Notify -->
        <mxCell id="notify" value="Уведомить менеджера" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="lane1">
          <mxGeometry x="1040" y="60" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Manager Task -->
        <mxCell id="task" value="Обработать заявку" style="rounded=1;fillColor=#e1d5e7;" vertex="1" parent="lane2">
          <mxGeometry x="1040" y="60" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Gateway 2 -->
        <mxCell id="gw2" value="Готово?" style="rhombus;fillColor=#fff2cc;" vertex="1" parent="lane2">
          <mxGeometry x="1280" y="50" width="80" height="80" as="geometry"/>
        </mxCell>

        <!-- Done -->
        <mxCell id="done" value="Завершить" style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="lane2">
          <mxGeometry x="1420" y="20" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Rework -->
        <mxCell id="rework" value="Доработать" style="rounded=1;fillColor=#f8cecc;" vertex="1" parent="lane2">
          <mxGeometry x="1420" y="120" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="End" style="ellipse;fillColor=#d5e8d4;" vertex="1" parent="lane1">
          <mxGeometry x="1650" y="60" width="60" height="60" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell edge="1" source="start" target="assign" parent="1"/>
        <mxCell edge="1" source="assign" target="gw1" parent="1"/>
        <mxCell edge="1" source="gw1" target="assignMain" parent="1"/>
        <mxCell edge="1" source="gw1" target="assignReserve" parent="1"/>
        <mxCell edge="1" source="assignMain" target="merge" parent="1"/>
        <mxCell edge="1" source="assignReserve" target="merge" parent="1"/>
        <mxCell edge="1" source="merge" target="update" parent="1"/>
        <mxCell edge="1" source="update" target="notify" parent="1"/>
        <mxCell edge="1" source="notify" target="task" parent="1"/>
        <mxCell edge="1" source="task" target="gw2" parent="1"/>
        <mxCell edge="1" source="gw2" target="done" parent="1"/>
        <mxCell edge="1" source="gw2" target="rework" parent="1"/>
        <mxCell edge="1" source="done" target="end" parent="1"/>
        <mxCell edge="1" source="rework" target="task" parent="1"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
